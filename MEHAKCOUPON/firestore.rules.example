rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contest config: anyone can read, only Firebase Console can write
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // User data: anyone can read mehak's doc; updates limited to known fields
    match /users/mehak {
      allow read: if true;
      allow update: if
        request.resource.data.keys().hasOnly(['points', 'contestsPlayed', 'lastPlayedDate'])
        && request.resource.data.points is number
        && request.resource.data.contestsPlayed is number
        && request.resource.data.lastPlayedDate is string;
      allow create: if true;
      allow delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
