rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contest config: anyone can read, only Firebase Console can write
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // User data: anyone can read mehak's doc; updates limited to known fields
    match /users/mehak {
      allow read: if true;
      allow update: if request.resource.data.keys().hasOnly([
        'points',
        'contestsPlayed',
        'lastPlayedDate',
        'flappyTriesUsed',
        'flappyTotalEarned',
        'mazeTriesUsed',
        'mazeTotalEarned',
        'mazeCompleted',
        'bbLevelsCleared',
        'bbTotalEarned',
        'bbCompleted'
      ]);
      allow create: if true;
      allow delete: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
